 remember it), choose your region, and tick the two security options as shown in the screenshot. Click create project to finish. 1.3 Create Database Tables Enter your created project, select the \u0026amp;ldquo;SQL Editor\u0026amp;rdquo; from the sidebar, and open an \u0026amp;ldquo;Untitled query\u0026amp;rdquo; (click the + icon to create …","date":1782363840,"dir":"post\\coding1-waline\\","expirydate":-62135596800,"fuzzywordcount":1200,"html":"Deploy a serverless comment backend using Waline V3, bind it with Supabase (PostgreSQL) for data storage, and embed it into a Hugo blog. This article provides a detailed step-by-step configuration to achieve a seamless, login-free commenting experience for guests.","keywords":null,"kind":"page","lang":"en","lastmod":1782363840,"objectID":"247366e4b41bcb7ae6d051e60eb61d61","permalink":"http://localhost:1313/en/2026/6/25/waline-comment/","publishdate":"2026-06-25T00:00:00+08:00","readingtime":6,"relpermalink":"/en/2026/6/25/waline-comment/","section":"post","tags":["waline","supabase","hugo"],"title":"Waline V3 + Supabase Pitfall Guide: Implementing a Serverless Comment System for Hugo","type":"post","url":"/en/2026/6/25/waline-comment/","weight":0,"wordcount":1125},{"author":null,"categories":null,"content":"","date":-62135596800,"dir":"about\\","expirydate":-62135596800,"fuzzywordcount":100,"html":null,"keywords":null,"kind":"page","lang":"en","lastmod":-62135596800,"objectID":"c29b9617fa2d0de4785d09bf94799bfb","permalink":"http://localhost:1313/en/about/","publishdate":"0001-01-01T00:00:00Z","readingtime":0,"relpermalink":"/en/about/","section":"","tags":null,"title":"About","type":"page","url":"/en/about/","weight":0,"wordcount":0},{"author":null,"categories":null,"content":"Welcome to my guestbook! Feel free to leave a message below:\n","date":-62135596800,"dir":"message\\","expirydate":-62135596800,"fuzzywordcount":100,"html":null,"keywords":null,"kind":"page","lang":"en","lastmod":-62135596800,"objectID":"1c78c983f48fd